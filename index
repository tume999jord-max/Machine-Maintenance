async function fetchJSON(url) {
  const res = await fetch(url, { redirect: 'follow' });
  const text = await res.text();
  try { return JSON.parse(text); } catch(e) { return null; }
}

async function loadLiveData() {
  setLoading(['s-repair','s-order','s-replace','s-pending',
              'stat-repair','stat-order','stat-replace','stat-avg']);

  const [repairData, orderData, replaceData] = await Promise.allSettled([
    fetchJSON(URLS.repair  + '?action=getStatus'),
    fetchJSON(URLS.order   + '?action=getOrderSummary'),
    fetchJSON(URLS.replace + '?action=getSummary')
  ]);

  const repair  = repairData.status  === 'fulfilled' ? repairData.value  : null;
  const order   = orderData.status   === 'fulfilled' ? orderData.value   : null;
  const replace = replaceData.status === 'fulfilled' ? replaceData.value : null;

  // ===== HERO STATS =====
  const repairTotal   = repair  ? (repair.pendingCount  || 0) : '—';
  const orderTotal    = order   ? (order.total          || 0) : '—';
  const replaceTotal  = replace ? (replace.totalItems   || 0) : '—';
  const pendingRepair = repair  ? (repair.urgentCount   || 0) : '—';

  setVal('s-repair',  repairTotal);
  setVal('s-order',   orderTotal);
  setVal('s-replace', replaceTotal);
  setVal('s-pending', pendingRepair);
  setVal('s-pending-home', pendingRepair);

  // ===== HOME SUMMARY CARDS =====
  setVal('stat-repair',  repair  ? (repair.pendingCount || 0) + ' งาน'  : '—');
  setVal('stat-order',   order   ? (order.total || 0) + ' รายการ'       : '—');
  setVal('stat-replace', replace ? (replace.totalItems || 0) + ' รายการ': '—');

  // Order value
  if (order && order.totalValue) {
    setVal('stat-avg', '฿' + Number(order.totalValue).toLocaleString('th-TH', {maximumFractionDigits:0}));
  } else {
    setVal('stat-avg', '—');
  }

  // ===== ACTIVITY FEED from live data =====
  liveActivities = [];

  if (repair && repair.recentPending) {
    repair.recentPending.forEach(r => {
      liveActivities.push({
        type:'repair', icon:'tool',
        title: 'ซ่อม ' + (r.machine || '-') + (r.type ? ' · ' + r.type : ''),
        sub:   (r.tech || '-') + (r.problem ? ' · ' + r.problem.slice(0,30) : ''),
        badge:'b-open', btext:'กำลังดำเนินการ',
        time: r.startDate || ''
      });
    });
  }

  if (order && order.recentOrders) {
    order.recentOrders.forEach(o => {
      const badgeMap = {
        'ได้รับแล้ว':'b-done','รอซัพส่งของ':'b-pending',
        'รออนุมัติ PO':'b-open','รอเปิด PO':'b-open',
        'รออนุมัติ PR':'b-pending','รอเปิด PR':'b-pending'
      };
      liveActivities.push({
        type:'order', icon:'shopping-cart',
        title: 'สั่ง ' + (o.item || '-'),
        sub:   (o.dept || '') + (o.vender ? ' · ' + o.vender : ''),
        badge: badgeMap[o.status] || 'b-open',
        btext: o.status || '-',
        time:  ''
      });
    });
  }

  if (replace && replace.recentItems) {
    replace.recentItems.forEach(r => {
      liveActivities.push({
        type:'replace', icon:'refresh',
        title: 'เปลี่ยน ' + (r.part || '-') + (r.machine ? ' · ' + r.machine : ''),
        sub:   (r.tech || '-'),
        badge:'b-done', btext:'เสร็จแล้ว',
        time: r.date || ''
      });
    });
  }

  // sort: repair (pending) first, then others
  liveActivities.sort((a,b) => {
    if (a.type === 'repair' && b.type !== 'repair') return -1;
    if (b.type === 'repair' && a.type !== 'repair') return 1;
    return 0;
  });

  // render home activity feed
  const homeAct = document.getElementById('activity-home');
  if (homeAct) {
    const preview = liveActivities.slice(0, 5);
    if (!preview.length) {
      homeAct.innerHTML = '<div style="text-align:center;padding:24px;color:var(--muted);font-size:13px">ยังไม่มีกิจกรรม</div>';
    } else {
      homeAct.innerHTML = preview.map(a => `
        <div class="act-item">
          <div class="act-icon ai-${a.type}"><i class="ti ti-${a.icon}"></i></div>
          <div class="act-body"><div class="act-title">${a.title}</div><div class="act-sub">${a.sub}</div></div>
          <span class="badge ${a.badge}">${a.btext}</span>
          <div class="act-time">${a.time}</div>
        </div>`).join('');
    }
  }

  // ===== ORDER SUMMARY CARDS =====
  if (order) {
    setVal('o-stat-total',    order.total      || 0);
    setVal('o-stat-value',    order.totalValue ? '฿'+Number(order.totalValue).toLocaleString('th-TH',{maximumFractionDigits:0}) : '—');
    setVal('o-stat-pending',  order.waiting    || 0);
    setVal('o-stat-progress', order.inProgress || 0);
    setVal('o-stat-received', order.received   || 0);
    const recvPct = order.total ? Math.round((order.received / order.total) * 100) : 0;
    const recvBar = document.getElementById('o-recv-bar');
    if (recvBar) recvBar.style.width = recvPct + '%';
    const recvPctEl = document.getElementById('o-recv-pct');
    if (recvPctEl) recvPctEl.textContent = recvPct + '%';
  }

  // ===== REPAIR SUMMARY =====
  if (repair) {
    setVal('r-stat-pending', repair.pendingCount || 0);
    const pct = repair.pendingCount ? Math.min(100, Math.round((repair.urgentCount / repair.pendingCount) * 100)) : 0;
    const rBar = document.getElementById('r-urgent-bar');
    if (rBar) rBar.style.width = pct + '%';
    const rPct = document.getElementById('r-urgent-pct');
    if (rPct) rPct.textContent = (repair.urgentCount || 0) + ' งานเร่งด่วน';
  }

  // ===== REPLACE SUMMARY =====
  if (replace) {
    setVal('p-stat-total', replace.totalItems || 0);
    setVal('p-stat-qty',   replace.totalQty   || 0);
    setVal('p-stat-top',   replace.topMachine || '—');
  }

  // update last-refresh time
  const now = new Date();
  const timeStr = now.toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'});
  const refreshEl = document.getElementById('last-refresh');
  if (refreshEl) refreshEl.textContent = 'อัปเดตล่าสุด: ' + timeStr;
}

// ===== BAR CHART (REPAIR) — will update after data loads =====
document.getElementById('bars-repair').innerHTML =
  '<div style="color:var(--muted);font-size:12px;padding:8px 0">⏳ กำลังโหลดข้อมูล...</div>';

// ===== SET TODAY DATE =====
const today = new Date().toISOString().split('T')[0];
['r-date','o-date','p-date'].forEach(id => document.getElementById(id).value = today);

// ===== INIT =====
loadLiveData();
</script>
