<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Machine Maintenance Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.9.0/dist/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --dark:#0D1117;
  --surface:#161B22;
  --card:#1C2128;
  --border:#30363D;
  --text:#E6EDF3;
  --muted:#8B949E;
  --blue:#58A6FF;
  --green:#3FB950;
  --purple:#C9A6FF;
  --warn:#D29922;
  --red:#F78166;
}
body{background:var(--dark);color:var(--text);font-family:'Noto Sans Thai','Inter',sans-serif;font-size:14px;min-height:100vh}

/* HERO */
.hero{background:var(--surface);border-bottom:1px solid var(--border);padding:28px 32px 22px}
.hero-inner{max-width:1100px;margin:0 auto;display:flex;gap:28px;align-items:flex-start;flex-wrap:wrap}
.hero-left{flex:1;min-width:260px}
.hero-badge{display:inline-flex;align-items:center;gap:7px;background:var(--dark);border:1px solid var(--border);border-radius:20px;padding:4px 14px;font-size:11px;color:var(--muted);margin-bottom:14px}
.pulse{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
h1{font-size:24px;font-weight:600;letter-spacing:-.3px;line-height:1.3}
h1 span{color:var(--red)}
.hero-sub{color:var(--muted);font-size:13px;margin-top:7px;line-height:1.7}
.hero-stats{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap}
.hstat{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:10px 18px;text-align:center}
.hstat-val{font-size:22px;font-weight:600}
.hstat-label{font-size:11px;color:var(--muted);margin-top:3px}
.c-blue{color:var(--blue)}.c-green{color:var(--green)}.c-warn{color:var(--warn)}.c-red{color:var(--red)}
.hero-right{display:flex;flex-direction:column;gap:8px;min-width:160px}
.qbtn{display:flex;align-items:center;gap:9px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:10px 15px;cursor:pointer;font-size:13px;color:var(--text);width:100%;transition:border-color .15s}
.qbtn:hover{border-color:var(--blue)}
.qbtn i{font-size:16px;color:var(--blue)}

/* NAV */
.nav-wrap{background:var(--surface);border-bottom:1px solid var(--border);padding:0 32px}
.nav-inner{max-width:1100px;margin:0 auto;display:flex;overflow-x:auto}
.tab{padding:12px 18px;font-size:13px;cursor:pointer;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:7px;white-space:nowrap;transition:color .15s}
.tab.active{color:var(--text);border-bottom-color:var(--red)}
.tab:hover:not(.active){color:var(--text)}
.tab i{font-size:15px}

/* CONTENT */
.content-wrap{max-width:1100px;margin:0 auto;padding:28px 32px}
.panel{display:none}.panel.active{display:block}

/* SECTION TITLE */
.sec-title{font-size:11px;font-weight:600;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border)}

/* SUMMARY CARDS */
.sum-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:28px}
.sum-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px 16px}
.sum-card-label{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:5px;margin-bottom:6px}
.sum-card-val{font-size:22px;font-weight:600}
.sum-card-sub{font-size:11px;color:var(--muted);margin-top:4px}

/* ACTIVITY */
.act-list{display:flex;flex-direction:column;gap:2px}
.act-item{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:7px;transition:background .1s}
.act-item:hover{background:var(--card)}
.act-icon{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px}
.ai-repair{background:#0D1F36;color:var(--blue)}
.ai-order{background:#0D1E0D;color:var(--green)}
.ai-replace{background:#1A1028;color:var(--purple)}
.ai-warn{background:#2A2314;color:var(--warn)}
.act-body{flex:1;min-width:0}
.act-title{font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.act-sub{font-size:11px;color:var(--muted);margin-top:2px}
.act-time{font-size:11px;color:var(--muted);flex-shrink:0}
.badge{font-size:10px;padding:2px 9px;border-radius:10px;flex-shrink:0}
.b-done{background:#122111;color:var(--green);border:1px solid #2d5a2d}
.b-pending{background:#2A2314;color:var(--warn);border:1px solid #5a4a14}
.b-open{background:#0D1F36;color:var(--blue);border:1px solid #1f4080}

/* TOOLS GRID */
.tools-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:18px}
.tool-card{background:var(--card);border:1px solid var(--border);border-radius:11px;overflow:hidden}
.tc-head{padding:14px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:11px}
.tc-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.tci-blue{background:#0D1F36;color:var(--blue)}
.tci-green{background:#0D1E0D;color:var(--green)}
.tci-purple{background:#1A1028;color:var(--purple)}
.tc-title{font-size:14px;font-weight:500}
.tc-sub{font-size:11px;color:var(--muted)}
.tc-body{padding:16px 18px}
.form-row{margin-bottom:11px}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:11px}
label{display:block;font-size:11px;color:var(--muted);font-weight:500;margin-bottom:4px}
input,select,textarea{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:8px 11px;font-size:12px;color:var(--text);width:100%;font-family:inherit;outline:none;transition:border-color .15s}
input:focus,select:focus,textarea:focus{border-color:var(--blue)}
select option{background:var(--card)}
.total-box{background:var(--surface);border-radius:7px;padding:9px 14px;display:flex;justify-content:space-between;align-items:center;margin-bottom:11px}
.total-box span:first-child{font-size:12px;color:var(--muted)}
.total-val{font-size:17px;font-weight:600;color:var(--green)}
.btn-submit{width:100%;padding:9px;border-radius:7px;border:none;cursor:pointer;font-size:13px;font-weight:500;display:flex;align-items:center;justify-content:center;gap:7px;transition:opacity .15s,transform .1s}
.btn-submit:hover{opacity:.88}
.btn-submit:active{transform:scale(.98)}
.btn-submit:disabled{opacity:.5;cursor:not-allowed}
.btn-blue{background:var(--blue);color:#0D1117}
.btn-green{background:var(--green);color:#0D1117}
.btn-purple{background:#7C3AED;color:#fff}
.recent-list{margin-top:14px;border-top:1px solid var(--border);padding-top:12px}
.recent-label{font-size:11px;color:var(--muted);margin-bottom:8px}
.recent-item{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px}
.recent-item:last-child{border:none}
.ri-val{font-size:11px;color:var(--muted)}

/* PM ALERTS */
.pm-item{background:var(--surface);border-radius:7px;padding:11px 14px;margin-bottom:8px}
.pm-item.urgent{border-left:3px solid var(--red)}
.pm-item.soon{border-left:3px solid var(--warn)}
.pm-item.ok{border-left:3px solid var(--blue)}
.pm-name{font-size:13px;font-weight:500}
.pm-detail{font-size:11px;color:var(--muted);margin-top:3px}
.pm-status{font-size:10px;margin-top:3px}

/* FILTER BTNS */
.filter-bar{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap}
.fbtn{background:var(--card);color:var(--muted);border:1px solid var(--border);border-radius:6px;padding:5px 14px;font-size:12px;cursor:pointer;transition:all .15s}
.fbtn.active{background:var(--blue);color:#0D1117;border-color:var(--blue)}

/* TOAST */
.toast{position:fixed;bottom:24px;right:24px;background:var(--card);border-radius:9px;padding:11px 18px;font-size:13px;display:none;align-items:center;gap:9px;z-index:999;box-shadow:0 4px 24px rgba(0,0,0,.5)}
.toast.success{border:1px solid var(--green);color:var(--green)}
.toast.error{border:1px solid var(--red);color:var(--red)}
.toast.loading{border:1px solid var(--blue);color:var(--blue)}

/* SPINNER */
.spin{display:inline-block;width:14px;height:14px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}

/* FOOTER */
footer{text-align:center;padding:24px;color:var(--muted);font-size:12px;border-top:1px solid var(--border);margin-top:40px}

@media(max-width:600px){
  .hero-inner{gap:18px}
  .content-wrap{padding:20px 16px}
  .hero,.nav-wrap{padding-left:16px;padding-right:16px}
  .tools-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-badge"><span class="pulse"></span> ระบบออนไลน์ · อัปเดตแบบ Real-time</div>
      <h1>แผนก <span>Machine Maintenance</span></h1>
      <p class="hero-sub">ศูนย์กลางการบำรุงรักษา ซ่อมแซม และจัดการอะไหล่เครื่องจักร<br>ทุกการบันทึกเชื่อมตรงสู่ Google Sheets แบบ Real-time</p>
      <div class="hero-stats">
        <div class="hstat"><div class="hstat-val c-blue" id="s-repair">—</div><div class="hstat-label">งานซ่อมค้าง</div></div>
        <div class="hstat"><div class="hstat-val c-green" id="s-order">—</div><div class="hstat-label">สั่งอะไหล่ทั้งหมด</div></div>
        <div class="hstat"><div class="hstat-val" style="color:var(--purple)" id="s-replace">—</div><div class="hstat-label">เปลี่ยนอะไหล่</div></div>
        <div class="hstat"><div class="hstat-val c-red" id="s-pending">—</div><div class="hstat-label">งานเร่งด่วน</div></div>
      </div>
    </div>
    <div class="hero-right">
      <button class="qbtn" onclick="switchTab('repair')"><i class="ti ti-tool"></i> บันทึกการซ่อม</button>
      <button class="qbtn" onclick="switchTab('order')"><i class="ti ti-shopping-cart"></i> สั่งอะไหล่</button>
      <button class="qbtn" onclick="switchTab('replace')"><i class="ti ti-refresh"></i> เปลี่ยนอะไหล่</button>
      <button class="qbtn" onclick="switchTab('activity')"><i class="ti ti-history"></i> กิจกรรมล่าสุด</button>
    </div>
  </div>
</div>

<!-- NAV -->
<div class="nav-wrap">
  <div class="nav-inner">
    <div class="tab active" id="tab-home" onclick="switchTab('home')"><i class="ti ti-layout-dashboard"></i> หน้าหลัก</div>
    <div class="tab" id="tab-repair" onclick="switchTab('repair')"><i class="ti ti-tool"></i> ซ่อมเครื่อง</div>
    <div class="tab" id="tab-order" onclick="switchTab('order')"><i class="ti ti-shopping-cart"></i> สั่งอะไหล่</div>
    <div class="tab" id="tab-replace" onclick="switchTab('replace')"><i class="ti ti-refresh"></i> เปลี่ยนอะไหล่</div>
    <div class="tab" id="tab-activity" onclick="switchTab('activity')"><i class="ti ti-history"></i> กิจกรรม</div>
  </div>
</div>

<!-- ===== HOME ===== -->
<div class="content-wrap panel active" id="panel-home">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px">
    <div class="sec-title" style="margin:0;flex:1">สรุปข้อมูลปัจจุบัน (Real-time)</div>
    <div style="display:flex;align-items:center;gap:10px">
      <span id="last-refresh" style="font-size:11px;color:var(--muted)">กำลังโหลด...</span>
      <button onclick="loadLiveData()" style="background:var(--card);border:1px solid var(--border);border-radius:6px;padding:5px 12px;font-size:12px;color:var(--text);cursor:pointer;display:flex;align-items:center;gap:5px;font-family:inherit">
        <i class="ti ti-refresh" style="font-size:13px"></i> รีเฟรช
      </button>
    </div>
  </div>
  <div class="sum-grid">
    <div class="sum-card">
      <div class="sum-card-label"><i class="ti ti-tool" style="color:var(--blue)"></i> งานซ่อมค้าง</div>
      <div class="sum-card-val c-blue" id="stat-repair">—</div>
      <div class="sum-card-sub">งานที่ยังไม่เสร็จ</div>
    </div>
    <div class="sum-card">
      <div class="sum-card-label"><i class="ti ti-package" style="color:var(--green)"></i> สั่งอะไหล่</div>
      <div class="sum-card-val c-green" id="stat-order">—</div>
      <div class="sum-card-sub" id="stat-avg">มูลค่ารวม</div>
    </div>
    <div class="sum-card">
      <div class="sum-card-label"><i class="ti ti-refresh" style="color:var(--purple)"></i> เปลี่ยนอะไหล่</div>
      <div class="sum-card-val" style="color:var(--purple)" id="stat-replace">—</div>
      <div class="sum-card-sub">รายการทั้งหมด</div>
    </div>
    <div class="sum-card">
      <div class="sum-card-label"><i class="ti ti-alert-triangle" style="color:var(--warn)"></i> งานเร่งด่วน</div>
      <div class="sum-card-val c-warn" id="s-pending-home">—</div>
      <div class="sum-card-sub">ต้องดำเนินการ</div>
    </div>
  </div>

  <div class="sec-title">กิจกรรมล่าสุด (จาก Google Sheets)</div>
  <div class="act-list" id="activity-home">
    <div style="text-align:center;padding:28px;color:var(--muted);font-size:13px;display:flex;align-items:center;justify-content:center;gap:10px">
      <span class="spin" style="width:16px;height:16px;border-width:2px;display:inline-block"></span>
      กำลังดึงข้อมูลจาก Google Sheets...
    </div>
  </div>
</div>

<!-- ===== REPAIR ===== -->
<div class="content-wrap panel" id="panel-repair">
  <div class="sec-title">บันทึกการซ่อม</div>
  <div class="tools-grid">
    <div class="tool-card">
      <div class="tc-head">
        <div class="tc-icon tci-blue"><i class="ti ti-tool"></i></div>
        <div><div class="tc-title">แบบฟอร์มซ่อมเครื่องจักร</div><div class="tc-sub">บันทึกตรงสู่ Google Sheets</div></div>
      </div>
      <div class="tc-body">
        <div class="form-row"><label>วันที่ซ่อม</label><input type="date" id="r-date"></div>
        <div class="form-row"><label>ชื่อเครื่องจักร / รหัส</label><input type="text" id="r-machine" placeholder="เช่น CNC-02, ปั๊ม HY-03"></div>
        <div class="form-row"><label>อาการเสีย / ปัญหา</label><input type="text" id="r-problem" placeholder="อธิบายอาการที่พบ"></div>
        <div class="form-row-2">
          <div><label>ช่างผู้รับผิดชอบ</label><input type="text" id="r-tech" placeholder="ชื่อช่าง"></div>
          <div><label>เวลาที่ใช้ (ชม.)</label><input type="number" id="r-hours" placeholder="0.0" step="0.5" min="0"></div>
        </div>
        <div class="form-row"><label>วิธีแก้ไข / สรุปงาน</label><input type="text" id="r-solution" placeholder="บอกวิธีการแก้ไข"></div>
        <div class="form-row">
          <label>สถานะ</label>
          <select id="r-status">
            <option value="เสร็จแล้ว">เสร็จแล้ว</option>
            <option value="กำลังดำเนินการ">กำลังดำเนินการ</option>
            <option value="รอดำเนินการ">รอดำเนินการ</option>
          </select>
        </div>
        <button class="btn-submit btn-blue" id="btn-repair" onclick="submitRepair()">
          <i class="ti ti-device-floppy"></i> บันทึกการซ่อม
        </button>
        <div class="recent-list">
          <div class="recent-label">รายการล่าสุด</div>
          <div class="recent-item"><span>ปั๊มไฮดรอลิค #HY-03</span><span class="ri-val">วันนี้ · 1.5 ชม.</span></div>
          <div class="recent-item"><span>มอเตอร์ 5.5kW Line B</span><span class="ri-val">10 มิ.ย. · 3 ชม.</span></div>
          <div class="recent-item"><span>CNC-01 แกน X เสีย</span><span class="ri-val">8 มิ.ย. · 5 ชม.</span></div>
        </div>
      </div>
    </div>

    <div class="tool-card">
      <div class="tc-head">
        <div class="tc-icon tci-blue"><i class="ti ti-chart-bar"></i></div>
        <div><div class="tc-title">สถิติการซ่อมเดือนนี้</div><div class="tc-sub">มิถุนายน 2568</div></div>
      </div>
      <div class="tc-body">
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="background:var(--surface);border-radius:7px;padding:12px 14px">
            <div style="font-size:11px;color:var(--muted);margin-bottom:10px">งานซ่อมตามเครื่อง</div>
            <div id="bars-repair"></div>
          </div>
          <div style="background:var(--surface);border-radius:7px;padding:12px 14px">
            <div style="font-size:11px;color:var(--muted);margin-bottom:8px">อัตราการเสร็จงาน</div>
            <div style="display:flex;gap:10px;align-items:center">
              <div style="flex:1;background:var(--border);border-radius:4px;height:8px;overflow:hidden">
                <div style="background:var(--green);height:100%;width:81%;border-radius:4px"></div>
              </div>
              <span style="font-size:12px;color:var(--green);font-weight:500">81%</span>
            </div>
          </div>
          <div style="background:var(--surface);border-radius:7px;padding:12px 14px">
            <div style="display:flex;justify-content:space-between;margin-bottom:6px">
              <span style="font-size:12px;color:var(--muted)">เฉลี่ยเวลาต่องาน</span>
              <span style="font-size:13px;font-weight:500;color:var(--blue)">2.4 ชม.</span>
            </div>
            <div style="display:flex;justify-content:space-between">
              <span style="font-size:12px;color:var(--muted)">งานซ่อมทั้งหมดเดือนนี้</span>
              <span style="font-size:13px;font-weight:500;color:var(--text)">12 งาน</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ===== ORDER ===== -->
<div class="content-wrap panel" id="panel-order">
  <div class="sec-title">บันทึกการสั่งอะไหล่</div>
  <div class="tools-grid">
    <div class="tool-card">
      <div class="tc-head">
        <div class="tc-icon tci-green"><i class="ti ti-shopping-cart"></i></div>
        <div><div class="tc-title">แบบฟอร์มสั่งซื้ออะไหล่</div><div class="tc-sub">บันทึกตรงสู่ Google Sheets</div></div>
      </div>
      <div class="tc-body">
        <div class="form-row"><label>วันที่สั่ง</label><input type="date" id="o-date"></div>
        <div class="form-row"><label>ชื่ออะไหล่ / รหัสสินค้า</label><input type="text" id="o-part" placeholder="เช่น Oil Seal 45×65×10, V-Belt B68"></div>
        <div class="form-row-2">
          <div><label>จำนวน</label><input type="number" id="o-qty" placeholder="0" min="1" oninput="calcTotal()"></div>
          <div><label>ราคา/หน่วย (บาท)</label><input type="number" id="o-price" placeholder="0.00" step="0.01" oninput="calcTotal()"></div>
        </div>
        <div class="form-row"><label>ซัพพลายเออร์</label><input type="text" id="o-supplier" placeholder="ชื่อผู้จำหน่าย"></div>
        <div class="form-row"><label>หมายเหตุ / เหตุผลการสั่ง</label><input type="text" id="o-note" placeholder="ระบุเหตุผลหรือรายละเอียด"></div>
        <div class="form-row">
          <label>สถานะ</label>
