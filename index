// ===== SEND TO APPS SCRIPT =====
async function sendToSheet(url, data, btnId, successMsg) {
  const btn = document.getElementById(btnId);
  btn.disabled = true;
  btn.innerHTML = '<span class="spin"></span> กำลังบันทึก...';
  showToast('กำลังบันทึกข้อมูล...', 'loading');

  try {
    const params = new URLSearchParams(data);
    const res = await fetch(url + '?' + params.toString(), { method: 'GET' });
    const text = await res.text();
    showToast(successMsg, 'success');
    return true;
  } catch (e) {
    showToast('เกิดข้อผิดพลาด กรุณาลองใหม่', 'error');
    return false;
  } finally {
    btn.disabled = false;
  }
}

// ===== REPAIR =====
async function submitRepair() {
  const machine = document.getElementById('r-machine').value.trim();
  const problem = document.getElementById('r-problem').value.trim();
  if (!machine) { alert('กรุณากรอกชื่อเครื่องจักร'); return; }
  if (!problem) { alert('กรุณากรอกอาการเสีย/ปัญหา'); return; }

  const data = {
    date:     document.getElementById('r-date').value,
    machine:  machine,
    problem:  problem,
    tech:     document.getElementById('r-tech').value,
    hours:    document.getElementById('r-hours').value,
    solution: document.getElementById('r-solution').value,
    status:   document.getElementById('r-status').value
  };

  const ok = await sendToSheet(URLS.repair, data, 'btn-repair', 'บันทึกการซ่อม "' + machine + '" สำเร็จแล้ว ✓');
  if (ok) {
    ['r-machine','r-problem','r-tech','r-hours','r-solution'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('btn-repair').innerHTML = '<i class="ti ti-device-floppy"></i> บันทึกการซ่อม';
  }
}

// ===== ORDER =====
async function submitOrder() {
  const part = document.getElementById('o-part').value.trim();
  const qty  = document.getElementById('o-qty').value;
  if (!part) { alert('กรุณากรอกชื่ออะไหล่'); return; }
  if (!qty || qty < 1) { alert('กรุณากรอกจำนวน'); return; }

  const data = {
    date:     document.getElementById('o-date').value,
    part:     part,
    qty:      qty,
    price:    document.getElementById('o-price').value,
    total:    (parseFloat(qty) * parseFloat(document.getElementById('o-price').value || 0)).toFixed(2),
    supplier: document.getElementById('o-supplier').value,
    note:     document.getElementById('o-note').value,
    status:   document.getElementById('o-status').value
  };

  const ok = await sendToSheet(URLS.order, data, 'btn-order', 'บันทึกคำสั่งซื้อ "' + part + '" สำเร็จแล้ว ✓');
  if (ok) {
    ['o-part','o-qty','o-price','o-supplier','o-note'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('o-total').textContent = '0 บาท';
    document.getElementById('btn-order').innerHTML = '<i class="ti ti-device-floppy"></i> บันทึกคำสั่งซื้อ';
  }
}

