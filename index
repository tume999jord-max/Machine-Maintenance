// ===== TOAST =====
let toastTimer;
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  const m = document.getElementById('toast-msg');
  const ic = document.getElementById('toast-icon');
  t.className = 'toast ' + type;
  m.textContent = msg;
  ic.className = type === 'loading' ? 'spin' : (type === 'error' ? 'ti ti-x' : 'ti ti-check');
  t.style.display = 'flex';
  clearTimeout(toastTimer);
  if (type !== 'loading') toastTimer = setTimeout(() => t.style.display = 'none', 3000);
}

// ===== TABS =====
function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.getElementById('panel-' + name).classList.add('active');
  if (name === 'activity') renderActs('all');
}

// ===== ACTIVITY (live data) =====
let liveActivities = [];
let currentFilter  = 'all';

function renderActs(filter) {
  currentFilter = filter;
  const list = filter === 'all' ? liveActivities : liveActivities.filter(a => a.type === filter);
  const el   = document.getElementById('act-full');
