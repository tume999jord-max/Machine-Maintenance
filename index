// ===== FETCH LIVE DATA FROM ALL 3 SCRIPTS =====
function setVal(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function setLoading(ids) {
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.innerHTML = '<span class="spin" style="width:16px;height:16px;border-width:2px"></span>'; }
  });
